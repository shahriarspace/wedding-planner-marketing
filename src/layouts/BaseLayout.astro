---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import { url } from '../utils/url';
import { getLocaleFromUrl, t, SUPPORTED_LOCALES, localizedUrl, type Locale } from '../i18n/utils';
import '../styles/global.css';

// Determine locale from URL
const locale = getLocaleFromUrl(Astro.url) as Locale;

// Organization schema — injected on every page
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Merrily Plan',
  url: 'https://merrilyplan.com',
  logo: 'https://merrilyplan.com/favicon.svg',
  description: 'The all-in-one wedding planning app with 32+ planning tools, AI assistance, and multi-platform support.',
  sameAs: [],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    email: 'hello@merrilyplan.com',
    url: 'https://merrilyplan.com/contact',
  },
};

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  ogType?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = url('/og-image.png'),
  noindex = false,
  ogType = 'website',
  jsonLd,
} = Astro.props;

const siteTitle = 'Merrily Plan';
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : new URL(ogImage, Astro.site).href;

/**
 * Build hreflang URLs for the current page in all locales.
 * Strips current locale prefix and re-applies each locale.
 */
function getHreflangUrl(loc: string): string {
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  let pathname = Astro.url.pathname;

  // Strip base
  if (base && pathname.startsWith(base)) {
    pathname = pathname.slice(base.length);
  }

  // Strip existing locale prefix
  const segments = pathname.split('/').filter(Boolean);
  if (segments.length > 0) {
    const maybeLocale = segments[0];
    if (SUPPORTED_LOCALES.some((l) => l.code === maybeLocale) && maybeLocale !== 'en') {
      segments.shift();
    }
  }

  const cleanPath = '/' + segments.join('/');
  const localePath = localizedUrl(loc as Locale, cleanPath);
  return new URL(localePath, Astro.site).href;
}
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Canonical -->
    <link rel="canonical" href={canonical} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:locale" content={locale} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Sitemap -->
    <link rel="sitemap" href={url('/sitemap-index.xml')} />

    <!-- Hreflang tags for international SEO -->
    {SUPPORTED_LOCALES.map((loc) => (
      <link rel="alternate" hreflang={loc.code} href={getHreflangUrl(loc.code)} />
    ))}
    <link rel="alternate" hreflang="x-default" href={getHreflangUrl('en')} />

    <!-- JSON-LD Structured Data: Organization (every page) -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

    <!-- JSON-LD Structured Data: Page-specific -->
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <!-- Additional head content from pages -->
    <slot name="head" />

    <!-- Preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Non-render-blocking font loading -->
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600;1,700&family=Inter:wght@300;400;500;600;700&display=swap" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600;1,700&family=Inter:wght@300;400;500;600;700&display=swap" /></noscript>
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    <!-- Skip to main content link for keyboard/screen reader users -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-primary-600 focus:text-white focus:rounded-lg focus:shadow-lg focus:outline-none">
      {t(locale, 'nav.skipToContent')}
    </a>
    <Header lang={locale} />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer lang={locale} />
    <CookieConsent lang={locale} />
  </body>
</html>
