---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Pricing - Merrily Plan',
  description: 'Compare Free and Pro plans for Merrily Plan wedding planning app.',
  url: 'https://merrilyplan.com/pricing',
};

const freeFeatures = [
  'All 32 planning tabs',
  'Offline local storage',
  'JSON export & import',
  'Browser print support',
  'Single wedding plan',
  '10 language support',
  'PWA installable',
  'No account required',
];

const proFeatures = [
  'Everything in Free, plus:',
  'Unlimited wedding plans',
  'Cloud sync across devices',
  'Real-time collaboration',
  'AI-powered suggestions',
  'PDF export with branding',
  'Published wedding website',
  'Online RSVP management',
  'Plan sharing & team access',
  'Priority support',
];
---

<BaseLayout
  title="Pricing"
  description="Merrily Plan is free forever with all 32 planning tools. Upgrade to Pro for cloud sync, AI features, collaboration, and unlimited plans."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="py-16 md:py-24 bg-gradient-to-br from-primary-50 via-white to-accent-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="section-heading mb-4">
        Simple, Transparent
        <span class="gradient-text"> Pricing</span>
      </h1>
      <p class="section-subheading">
        Start free with all 32 planning tools. Upgrade when you need cloud sync, collaboration, and AI.
      </p>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="py-12 md:py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
        <!-- Free Plan -->
        <div class="rounded-2xl border-2 border-gray-200 p-8 md:p-10 relative">
          <div class="mb-8">
            <h2 class="text-2xl font-display font-bold text-gray-900 mb-2">Free</h2>
            <p class="text-gray-500">Perfect for couples planning their wedding</p>
          </div>

          <div class="mb-8">
            <div class="flex items-baseline gap-1">
              <span class="text-5xl font-display font-bold text-gray-900">$0</span>
              <span class="text-gray-500">/ forever</span>
            </div>
          </div>

          <a
            href="https://app.merrilyplan.com"
            class="btn-secondary w-full mb-8"
          >
            Get Started Free
          </a>

          <ul class="space-y-4">
            {freeFeatures.map((feature) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700">{feature}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Pro Plan -->
        <div class="rounded-2xl border-2 border-primary-500 p-8 md:p-10 relative shadow-xl shadow-primary-500/10">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2">
            <span class="inline-flex items-center px-4 py-1 rounded-full bg-gradient-to-r from-primary-600 to-accent-500 text-white text-sm font-semibold shadow-lg">
              Most Popular
            </span>
          </div>

          <div class="mb-8">
            <h2 class="text-2xl font-display font-bold text-gray-900 mb-2">Pro</h2>
            <p class="text-gray-500">For serious planners and professionals</p>
          </div>

          <div class="mb-8">
            <div class="flex items-baseline gap-1">
              <span class="text-5xl font-display font-bold text-gray-900">$9</span>
              <span class="text-gray-500">/ month</span>
            </div>
            <p class="text-sm text-gray-400 mt-1">or $79/year (save 27%)</p>
          </div>

          <a
            href="https://app.merrilyplan.com"
            class="btn-primary w-full mb-8"
          >
            Start Free Trial
          </a>

          <ul class="space-y-4">
            {proFeatures.map((feature, index) => (
              <li class:list={['flex items-start gap-3', index === 0 && 'font-semibold text-gray-900']}>
                {index > 0 && (
                  <svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                )}
                <span class:list={[index === 0 ? 'text-gray-900' : 'text-gray-700']}>
                  {feature}
                </span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-heading text-center mb-12">
        Frequently Asked Questions
      </h2>

      <div class="space-y-6">
        {[
          {
            q: 'Is the free plan really free forever?',
            a: 'Yes! The free plan includes all 32 planning tabs, offline storage, and JSON export/import. No credit card required, no trial period, no hidden fees.',
          },
          {
            q: 'Can I upgrade or downgrade at any time?',
            a: 'Absolutely. You can upgrade to Pro whenever you need cloud sync or collaboration features. Your free-tier data is preserved. You can downgrade anytime too -- your data stays on your device.',
          },
          {
            q: 'Do I need to create an account for the free plan?',
            a: 'No! The free plan works entirely offline using your browser\'s local storage. No account, no email, no sign-up. Just open the app and start planning.',
          },
          {
            q: 'What happens to my data if I cancel Pro?',
            a: 'Your data remains on your device and in your local storage. You can export it as JSON at any time. Cloud sync will stop, but nothing is deleted.',
          },
          {
            q: 'Is there a refund policy?',
            a: 'Yes, we offer a 30-day money-back guarantee on all Pro subscriptions. If you\'re not satisfied, contact us for a full refund.',
          },
          {
            q: 'Can professional wedding planners use this for multiple clients?',
            a: 'Yes! With the Pro plan, you get unlimited wedding plans, making it perfect for professional planners managing multiple weddings simultaneously.',
          },
        ].map(({ q, a }) => (
          <details class="group bg-white rounded-xl p-6 shadow-sm border border-gray-100 cursor-pointer">
            <summary class="flex items-center justify-between font-semibold text-gray-900 list-none">
              {q}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-4 text-gray-600 leading-relaxed">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-gradient-to-br from-primary-600 to-accent-600 text-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-display font-bold mb-4">
        Ready to Start Planning?
      </h2>
      <p class="text-lg text-white/80 mb-8">
        No credit card required. Start with the free plan today.
      </p>
      <a
        href="https://app.merrilyplan.com"
        class="inline-flex items-center px-10 py-4 rounded-full bg-white text-primary-700 font-semibold text-lg hover:bg-gray-100 transition-all duration-200 shadow-xl"
      >
        Start Planning Free
      </a>
    </div>
  </section>
</BaseLayout>
