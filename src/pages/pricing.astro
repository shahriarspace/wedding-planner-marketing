---
import BaseLayout from '../layouts/BaseLayout.astro';
import { appUrl } from '../utils/url';
import { getLocaleFromUrl, t, tArray, type Locale } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url) as Locale;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Pricing - Merrily Plan',
  description: 'Compare Free and Pro plans for Merrily Plan wedding planning app.',
  url: 'https://merrilyplan.com/pricing',
};

const freeFeatures = tArray(locale, 'pricing.free.features');
const proFeaturesHeader = t(locale, 'pricing.pro.featuresHeader');
const proFeatures = tArray(locale, 'pricing.pro.features');

const pricingFaqs = [
  { q: t(locale, 'pricing.faq.q1'), a: t(locale, 'pricing.faq.a1') },
  { q: t(locale, 'pricing.faq.q2'), a: t(locale, 'pricing.faq.a2') },
  { q: t(locale, 'pricing.faq.q3'), a: t(locale, 'pricing.faq.a3') },
  { q: t(locale, 'pricing.faq.q4'), a: t(locale, 'pricing.faq.a4') },
  { q: t(locale, 'pricing.faq.q5'), a: t(locale, 'pricing.faq.a5') },
  { q: t(locale, 'pricing.faq.q6'), a: t(locale, 'pricing.faq.a6') },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: pricingFaqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: a,
    },
  })),
};
---

<BaseLayout
  title={t(locale, 'pricing.meta.title')}
  description={t(locale, 'pricing.meta.description')}
  jsonLd={jsonLd}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <!-- Hero -->
  <section class="py-16 md:py-24 bg-gradient-to-br from-primary-50 via-white to-accent-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="section-heading mb-4">
        {t(locale, 'pricing.hero.heading')}
        <span class="gradient-text">{t(locale, 'pricing.hero.headingHighlight')}</span>
      </h1>
      <p class="section-subheading">
        {t(locale, 'pricing.hero.subheading')}
      </p>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="py-12 md:py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
        <!-- Free Plan -->
        <div class="rounded-2xl border-2 border-gray-200 p-8 md:p-10 relative">
          <div class="mb-8">
            <h2 class="text-2xl font-display font-bold text-gray-900 mb-2">{t(locale, 'pricing.free.title')}</h2>
            <p class="text-gray-500">{t(locale, 'pricing.free.subtitle')}</p>
          </div>

          <div class="mb-8">
            <div class="flex items-baseline gap-1">
              <span class="text-5xl font-display font-bold text-gray-900">{t(locale, 'pricing.free.price')}</span>
              <span class="text-gray-500">{t(locale, 'pricing.free.pricePeriod')}</span>
            </div>
          </div>

          <a
            href={appUrl(locale)}
            class="btn-secondary w-full mb-8"
          >
            {t(locale, 'pricing.free.cta')}
          </a>

          <ul class="space-y-4">
            {freeFeatures.map((feature) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700">{feature}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Pro Plan -->
        <div class="rounded-2xl border-2 border-primary-500 p-8 md:p-10 relative shadow-xl shadow-primary-500/10">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2">
            <span class="inline-flex items-center px-4 py-1 rounded-full bg-gradient-to-r from-primary-600 to-accent-500 text-white text-sm font-semibold shadow-lg">
              {t(locale, 'pricing.pro.badge')}
            </span>
          </div>

          <div class="mb-8">
            <h2 class="text-2xl font-display font-bold text-gray-900 mb-2">{t(locale, 'pricing.pro.title')}</h2>
            <p class="text-gray-500">{t(locale, 'pricing.pro.subtitle')}</p>
          </div>

          <div class="mb-8">
            <div class="flex items-baseline gap-1">
              <span class="text-5xl font-display font-bold text-gray-900">{t(locale, 'pricing.pro.price')}</span>
              <span class="text-gray-500">{t(locale, 'pricing.pro.pricePeriod')}</span>
            </div>
            <p class="text-sm text-gray-400 mt-1">{t(locale, 'pricing.pro.annualNote')}</p>
          </div>

          <a
            href={appUrl(locale)}
            class="btn-primary w-full mb-8"
          >
            {t(locale, 'pricing.pro.cta')}
          </a>

          <ul class="space-y-4">
            <li class="flex items-start gap-3 font-semibold text-gray-900">
              <span class="text-gray-900">{proFeaturesHeader}</span>
            </li>
            {proFeatures.map((feature) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700">{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-heading text-center mb-12">
        {t(locale, 'pricing.faq.heading')}
      </h2>

      <div class="space-y-6">
        {pricingFaqs.map(({ q, a }) => (
          <details class="group bg-white rounded-xl p-6 shadow-sm border border-gray-100 cursor-pointer">
            <summary class="flex items-center justify-between font-semibold text-gray-900 list-none">
              {q}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-4 text-gray-600 leading-relaxed">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-gradient-to-br from-primary-600 to-accent-600 text-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-display font-bold mb-4">
        {t(locale, 'pricing.cta.heading')}
      </h2>
      <p class="text-lg text-white/80 mb-8">
        {t(locale, 'pricing.cta.subheading')}
      </p>
      <a
        href={appUrl(locale)}
        class="inline-flex items-center px-10 py-4 rounded-full bg-white text-primary-700 font-semibold text-lg hover:bg-gray-100 transition-all duration-200 shadow-xl"
      >
        {t(locale, 'pricing.cta.button')}
      </a>
    </div>
  </section>
</BaseLayout>
