---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { localePath, appUrl } from '../../utils/url';
import { getLocaleFromUrl, t, type Locale } from '../../i18n/utils';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const locale = getLocaleFromUrl(Astro.url) as Locale;

const { post } = Astro.props;
const { Content } = await render(post);

const { title, description, date, author, image, tags = [] } = post.data;

// Map locale codes to BCP 47 locale strings for date formatting
const dateLocaleMap: Record<string, string> = {
  en: 'en-US', es: 'es-ES', fr: 'fr-FR', de: 'de-DE', pt: 'pt-BR',
  it: 'it-IT', ja: 'ja-JP', zh: 'zh-CN', ko: 'ko-KR', hi: 'hi-IN',
};
const dateLocaleStr = dateLocaleMap[locale] || 'en-US';

const formattedDate = new Date(date).toLocaleDateString(dateLocaleStr, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description,
  datePublished: date,
  author: {
    '@type': 'Organization',
    name: author || 'Merrily Plan Team',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Merrily Plan',
    url: 'https://merrilyplan.com',
  },
  ...(image && { image }),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: t(locale, 'blog.post.breadcrumbHome'),
      item: 'https://merrilyplan.com',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: t(locale, 'blog.post.breadcrumbBlog'),
      item: 'https://merrilyplan.com/blog',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: title,
    },
  ],
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <!-- Breadcrumb navigation -->
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center text-sm text-gray-500 gap-2">
        <li>
          <a href={localePath(locale, '/')} class="hover:text-primary-600 transition-colors">{t(locale, 'blog.post.breadcrumbHome')}</a>
        </li>
        <li aria-hidden="true">
          <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </li>
        <li>
          <a href={localePath(locale, '/blog')} class="hover:text-primary-600 transition-colors">{t(locale, 'blog.post.breadcrumbBlog')}</a>
        </li>
        <li aria-hidden="true">
          <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </li>
        <li>
          <span class="text-gray-900 font-medium truncate max-w-[200px] inline-block" aria-current="page">{title}</span>
        </li>
      </ol>
    </nav>

    <!-- Header -->
    <header class="mb-12">
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-4">
          {tags.map((tag: string) => (
            <span class="text-xs font-medium px-3 py-1 rounded-full bg-primary-100 text-primary-700">
              {tag}
            </span>
          ))}
        </div>
      )}
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-display font-bold text-gray-900 mb-4 leading-tight">
        {title}
      </h1>
      <div class="flex items-center text-gray-500 text-sm">
        <span>{author || 'Merrily Plan Team'}</span>
        <span class="mx-2">&middot;</span>
        <time datetime={date}>{formattedDate}</time>
      </div>
    </header>

    <!-- Content -->
    <div class="prose prose-lg prose-gray max-w-none
                prose-headings:font-display prose-headings:font-bold
                prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4
                prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
                prose-p:leading-relaxed prose-p:text-gray-700
                prose-a:text-primary-600 prose-a:no-underline hover:prose-a:underline
                prose-strong:text-gray-900
                prose-ul:space-y-2 prose-ol:space-y-2
                prose-li:text-gray-700
                prose-blockquote:border-primary-300 prose-blockquote:bg-primary-50/50 prose-blockquote:py-1 prose-blockquote:px-6 prose-blockquote:rounded-r-lg
                prose-code:text-primary-700 prose-code:bg-primary-50 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
                prose-img:rounded-xl prose-img:shadow-lg">
      <Content />
    </div>

    <!-- CTA -->
    <div class="mt-16 p-8 bg-gradient-to-br from-primary-50 to-accent-50 rounded-2xl text-center">
      <h3 class="text-2xl font-display font-bold text-gray-900 mb-3">
        {t(locale, 'blog.post.ctaHeading')}
      </h3>
      <p class="text-gray-600 mb-6">
        {t(locale, 'blog.post.ctaText')}
      </p>
      <a href={appUrl(locale)} class="btn-primary">
        {t(locale, 'blog.post.ctaButton')}
      </a>
    </div>
  </article>
</BaseLayout>
