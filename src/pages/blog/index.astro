---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Merrily Plan Blog',
  description: 'Wedding planning tips, guides, and inspiration from Merrily Plan.',
  url: 'https://merrilyplan.com/blog',
  publisher: {
    '@type': 'Organization',
    name: 'Merrily Plan',
    url: 'https://merrilyplan.com',
  },
};
---

<BaseLayout
  title="Blog"
  description="Wedding planning tips, budget guides, vendor advice, and inspiration. Expert articles to help you plan your perfect day."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="py-16 md:py-24 bg-gradient-to-br from-primary-50 via-white to-accent-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="section-heading mb-4">
        Wedding Planning
        <span class="gradient-text"> Blog</span>
      </h1>
      <p class="section-subheading">
        Expert guides, tips, and inspiration to help you plan your dream wedding.
      </p>
    </div>
  </section>

  <!-- Blog Posts Grid -->
  <section class="py-12 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {sortedPosts.length === 0 ? (
        <p class="text-center text-gray-500 text-lg">Coming soon! Check back for wedding planning articles.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {sortedPosts.map((post) => {
            const formattedDate = new Date(post.data.date).toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            });

            return (
              <article class="group">
                <a href={`/blog/${post.id}`} class="block">
                  <div class="card h-full flex flex-col group-hover:border-primary-200 transition-colors">
                    {/* Tags */}
                    {post.data.tags && post.data.tags.length > 0 && (
                      <div class="flex flex-wrap gap-2 mb-4">
                        {post.data.tags.slice(0, 3).map((tag: string) => (
                          <span class="text-xs font-medium px-2.5 py-0.5 rounded-full bg-primary-100 text-primary-700">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}

                    {/* Title */}
                    <h2 class="text-xl font-display font-bold text-gray-900 mb-3 group-hover:text-primary-600 transition-colors leading-tight">
                      {post.data.title}
                    </h2>

                    {/* Description */}
                    <p class="text-gray-600 text-sm leading-relaxed mb-4 flex-1">
                      {post.data.description}
                    </p>

                    {/* Meta */}
                    <div class="flex items-center justify-between text-xs text-gray-400 pt-4 border-t border-gray-100">
                      <span>{post.data.author}</span>
                      <time datetime={post.data.date}>{formattedDate}</time>
                    </div>
                  </div>
                </a>
              </article>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="py-16 bg-gradient-to-br from-primary-50 to-accent-50">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-display font-bold text-gray-900 mb-4">
        Get Planning Tips in Your Inbox
      </h2>
      <p class="text-gray-600 mb-8">
        Subscribe to our newsletter for weekly wedding planning advice, budget tips, and inspiration.
      </p>
      <form
        id="newsletter-form"
        action="https://formspree.io/f/xwpkjqvr"
        method="POST"
        class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
      >
        <input
          type="email"
          name="email"
          placeholder="your@email.com"
          class="flex-1 px-5 py-3 rounded-full border border-gray-300 text-gray-900 placeholder-gray-400 focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
          required
          aria-label="Email address"
        />
        <input type="hidden" name="_subject" value="New newsletter subscriber - Merrily Plan" />
        <button type="submit" id="newsletter-btn" class="btn-primary whitespace-nowrap">
          Subscribe
        </button>
      </form>
      <!-- Success message (hidden by default) -->
      <div id="newsletter-success" class="hidden mt-4 p-4 rounded-xl bg-green-50 border border-green-200 max-w-md mx-auto">
        <div class="flex items-center justify-center gap-2">
          <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <p class="text-sm font-medium text-green-800">You're subscribed! Check your inbox for confirmation.</p>
        </div>
      </div>
      <!-- Error message (hidden by default) -->
      <div id="newsletter-error" class="hidden mt-4 p-4 rounded-xl bg-red-50 border border-red-200 max-w-md mx-auto">
        <p class="text-sm font-medium text-red-800">Something went wrong. Please try again.</p>
      </div>
      <p class="text-xs text-gray-400 mt-3">No spam. Unsubscribe anytime.</p>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement;
  const btn = document.getElementById('newsletter-btn') as HTMLButtonElement;
  const successEl = document.getElementById('newsletter-success');
  const errorEl = document.getElementById('newsletter-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Sending...';
    errorEl?.classList.add('hidden');

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (response.ok) {
        form.style.display = 'none';
        successEl?.classList.remove('hidden');
      } else {
        throw new Error('Submission failed');
      }
    } catch {
      errorEl?.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Subscribe';
    }
  });
</script>
