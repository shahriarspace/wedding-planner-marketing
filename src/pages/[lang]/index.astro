---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { localePath, appUrl } from '../../utils/url';
import { getLocaleFromUrl, t, SUPPORTED_LOCALES, DEFAULT_LOCALE, type Locale } from '../../i18n/utils';

export function getStaticPaths() {
  return SUPPORTED_LOCALES
    .filter((l) => l.code !== DEFAULT_LOCALE)
    .map((l) => ({ params: { lang: l.code } }));
}

const locale = getLocaleFromUrl(Astro.url) as Locale;

const homeFaqs = [
  { q: t(locale, 'home.faq.q1'), a: t(locale, 'home.faq.a1') },
  { q: t(locale, 'home.faq.q2'), a: t(locale, 'home.faq.a2') },
  { q: t(locale, 'home.faq.q3'), a: t(locale, 'home.faq.a3') },
  { q: t(locale, 'home.faq.q4'), a: t(locale, 'home.faq.a4') },
  { q: t(locale, 'home.faq.q5'), a: t(locale, 'home.faq.a5') },
  { q: t(locale, 'home.faq.q6'), a: t(locale, 'home.faq.a6') },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: homeFaqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: a,
    },
  })),
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Merrily Plan',
  applicationCategory: 'LifestyleApplication',
  operatingSystem: 'Web, Android, iOS, Windows, macOS, Linux',
  url: 'https://merrilyplan.com',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
    description: 'Free tier with all 32 planning tabs',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    ratingCount: '1200',
  },
  description: t(locale, 'home.meta.description'),
};

const features = [
  {
    icon: 'clipboard-list',
    title: t(locale, 'home.features.planningTabs'),
    description: t(locale, 'home.features.planningTabsDesc'),
  },
  {
    icon: 'sparkles',
    title: t(locale, 'home.features.aiAssistance'),
    description: t(locale, 'home.features.aiAssistanceDesc'),
  },
  {
    icon: 'users',
    title: t(locale, 'home.features.collaborate'),
    description: t(locale, 'home.features.collaborateDesc'),
  },
  {
    icon: 'smartphone',
    title: t(locale, 'home.features.worksEverywhere'),
    description: t(locale, 'home.features.worksEverywhereDesc'),
  },
  {
    icon: 'lock',
    title: t(locale, 'home.features.dataPrivacy'),
    description: t(locale, 'home.features.dataPrivacyDesc'),
  },
  {
    icon: 'globe',
    title: t(locale, 'home.features.tenLanguages'),
    description: t(locale, 'home.features.tenLanguagesDesc'),
  },
];

const tabGroups = [
  {
    category: t(locale, 'home.tabs.gettingStarted'),
    tabs: [t(locale, 'home.tabs.setup'), t(locale, 'home.tabs.priorities'), t(locale, 'home.tabs.coupleProfile'), t(locale, 'home.tabs.moodboard')],
  },
  {
    category: t(locale, 'home.tabs.budgetFinances'),
    tabs: [t(locale, 'home.tabs.weddingBudget'), t(locale, 'home.tabs.honeymoonBudget')],
  },
  {
    category: t(locale, 'home.tabs.guestsSeating'),
    tabs: [t(locale, 'home.tabs.guestList'), t(locale, 'home.tabs.seatingPlan'), t(locale, 'home.tabs.weddingParty'), t(locale, 'home.tabs.invitations')],
  },
  {
    category: t(locale, 'home.tabs.planningTasks'),
    tabs: [t(locale, 'home.tabs.taskTracker'), t(locale, 'home.tabs.appointments'), t(locale, 'home.tabs.smartCalendar')],
  },
  {
    category: t(locale, 'home.tabs.vendors'),
    tabs: [t(locale, 'home.tabs.venueOptions'), t(locale, 'home.tabs.vendorComparison'), t(locale, 'home.tabs.confirmedVendors'), t(locale, 'home.tabs.vendorQuestions')],
  },
  {
    category: t(locale, 'home.tabs.eventDetails'),
    tabs: [t(locale, 'home.tabs.foodDrinks'), t(locale, 'home.tabs.logistics'), t(locale, 'home.tabs.decor'), t(locale, 'home.tabs.musicPlaylist'), t(locale, 'home.tabs.photoShotlist')],
  },
  {
    category: t(locale, 'home.tabs.theBigDay'),
    tabs: [t(locale, 'home.tabs.dayTimeline'), t(locale, 'home.tabs.packingList')],
  },
  {
    category: t(locale, 'home.tabs.afterWedding'),
    tabs: [t(locale, 'home.tabs.giftThankYou'), t(locale, 'home.tabs.coupleBlog')],
  },
  {
    category: t(locale, 'home.tabs.overviewExport'),
    tabs: [t(locale, 'home.tabs.dashboard'), t(locale, 'home.tabs.printableSummary'), t(locale, 'home.tabs.weddingTrailer'), t(locale, 'home.tabs.inspirationGallery')],
  },
];

const testimonials = [
  {
    quote: t(locale, 'home.testimonials.quote1'),
    name: t(locale, 'home.testimonials.name1'),
    role: t(locale, 'home.testimonials.role1'),
  },
  {
    quote: t(locale, 'home.testimonials.quote2'),
    name: t(locale, 'home.testimonials.name2'),
    role: t(locale, 'home.testimonials.role2'),
  },
  {
    quote: t(locale, 'home.testimonials.quote3'),
    name: t(locale, 'home.testimonials.name3'),
    role: t(locale, 'home.testimonials.role3'),
  },
];

const stats = [
  { value: '32+', label: t(locale, 'home.stats.planningTools') },
  { value: '10', label: t(locale, 'home.stats.languages') },
  { value: '6', label: t(locale, 'home.stats.platforms') },
  { value: '100%', label: t(locale, 'home.stats.freeToStart') },
];
---

<BaseLayout
  title={t(locale, 'home.meta.title')}
  description={t(locale, 'home.meta.description')}
  jsonLd={jsonLd}
>
  <!-- FAQPage schema (separate from SoftwareApplication schema) -->
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-primary-50 via-white to-accent-50">
    <!-- Decorative elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-40 -right-40 w-80 h-80 rounded-full bg-primary-200/30 blur-3xl"></div>
      <div class="absolute -bottom-40 -left-40 w-80 h-80 rounded-full bg-accent-200/30 blur-3xl"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28 lg:py-36">
      <div class="text-center max-w-4xl mx-auto">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary-100 text-primary-700 text-sm font-medium mb-6 animate-fade-in">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
          </svg>
          {t(locale, 'home.hero.badge')}
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-display font-bold text-gray-900 leading-tight mb-6 animate-slide-up">
          {t(locale, 'home.hero.titleLine1')}
          <span class="gradient-text">{t(locale, 'home.hero.titleHighlight')}</span>
        </h1>

        <p class="text-lg md:text-xl text-gray-600 max-w-2xl mx-auto mb-10 animate-slide-up" style="animation-delay: 0.1s">
          {t(locale, 'home.hero.subtitle')}
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up" style="animation-delay: 0.2s">
          <a href={appUrl(locale)} class="btn-primary text-lg px-10 py-4">
            {t(locale, 'home.hero.ctaPrimary')}
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a href="#features" class="btn-secondary text-lg px-10 py-4">
            {t(locale, 'home.hero.ctaSecondary')}
          </a>
        </div>

        <!-- Stats -->
        <div class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-8 animate-fade-in" style="animation-delay: 0.4s">
          {stats.map(({ value, label }) => (
            <div class="text-center">
              <div class="text-3xl md:text-4xl font-display font-bold gradient-text">{value}</div>
              <div class="text-sm text-gray-500 mt-1">{label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section id="features" class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="section-heading mb-4">
          {t(locale, 'home.features.heading')}
          <span class="gradient-text">{t(locale, 'home.features.headingHighlight')}</span>
        </h2>
        <p class="section-subheading">
          {t(locale, 'home.features.subheading')}
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {features.map(({ icon, title, description }, index) => (
          <div class="card group" style={`animation-delay: ${index * 0.1}s`}>
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300">
              {icon === 'clipboard-list' && (
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                </svg>
              )}
              {icon === 'sparkles' && (
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                </svg>
              )}
              {icon === 'users' && (
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
              )}
              {icon === 'smartphone' && (
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
                </svg>
              )}
              {icon === 'lock' && (
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
              )}
              {icon === 'globe' && (
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              )}
            </div>
            <h3 class="text-xl font-display font-bold text-gray-900 mb-2">{title}</h3>
            <p class="text-gray-600 leading-relaxed">{description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- All 32 Tabs Section -->
  <section class="py-20 md:py-28 bg-gradient-to-br from-gray-50 to-primary-50/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="section-heading mb-4">
          {t(locale, 'home.tabs.heading')}
          <span class="gradient-text">{t(locale, 'home.tabs.headingHighlight')}</span>
        </h2>
        <p class="section-subheading">
          {t(locale, 'home.tabs.subheading')}
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {tabGroups.map(({ category, tabs }) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <h3 class="text-sm font-semibold uppercase tracking-wider text-primary-600 mb-3">{category}</h3>
            <ul class="space-y-2">
              {tabs.map((tab) => (
                <li class="flex items-center gap-2 text-gray-700">
                  <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {tab}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="section-heading mb-4">
          {t(locale, 'home.howItWorks.heading')}
          <span class="gradient-text">{t(locale, 'home.howItWorks.headingHighlight')}</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
        <div class="text-center">
          <div class="w-16 h-16 rounded-full bg-primary-100 text-primary-600 flex items-center justify-center mx-auto mb-6 text-2xl font-display font-bold">
            1
          </div>
          <h3 class="text-xl font-display font-bold text-gray-900 mb-3">{t(locale, 'home.howItWorks.step1Title')}</h3>
          <p class="text-gray-600">
            {t(locale, 'home.howItWorks.step1Desc')}
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 rounded-full bg-primary-100 text-primary-600 flex items-center justify-center mx-auto mb-6 text-2xl font-display font-bold">
            2
          </div>
          <h3 class="text-xl font-display font-bold text-gray-900 mb-3">{t(locale, 'home.howItWorks.step2Title')}</h3>
          <p class="text-gray-600">
            {t(locale, 'home.howItWorks.step2Desc')}
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 rounded-full bg-primary-100 text-primary-600 flex items-center justify-center mx-auto mb-6 text-2xl font-display font-bold">
            3
          </div>
          <h3 class="text-xl font-display font-bold text-gray-900 mb-3">{t(locale, 'home.howItWorks.step3Title')}</h3>
          <p class="text-gray-600">
            {t(locale, 'home.howItWorks.step3Desc')}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- App Preview / Screenshot Section -->
  <section class="py-16 md:py-28 bg-gradient-to-b from-white to-gray-50 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10 md:mb-16">
        <h2 class="section-heading mb-4">
          {t(locale, 'home.appPreview.heading')}
          <span class="gradient-text">{t(locale, 'home.appPreview.headingHighlight')}</span>
        </h2>
        <p class="section-subheading">
          {t(locale, 'home.appPreview.subheading')}
        </p>
      </div>

      <!-- Desktop mockup -->
      <div class="relative max-w-5xl mx-auto">
        <!-- Browser chrome frame -->
        <div class="bg-gray-800 rounded-t-xl sm:rounded-t-2xl px-3 sm:px-4 py-2 sm:py-3 flex items-center gap-2">
          <div class="flex gap-1 sm:gap-1.5">
            <div class="w-2 h-2 sm:w-3 sm:h-3 rounded-full bg-red-400"></div>
            <div class="w-2 h-2 sm:w-3 sm:h-3 rounded-full bg-yellow-400"></div>
            <div class="w-2 h-2 sm:w-3 sm:h-3 rounded-full bg-green-400"></div>
          </div>
          <div class="flex-1 flex justify-center">
            <div class="bg-gray-700 rounded-md sm:rounded-lg px-3 sm:px-4 py-1 text-[10px] sm:text-xs text-gray-400 max-w-xs w-full text-center">
              app.merrilyplan.com
            </div>
          </div>
        </div>

        <!-- App UI mockup content -->
        <div class="bg-white rounded-b-xl sm:rounded-b-2xl shadow-2xl border border-gray-200 border-t-0 overflow-hidden">
          <div class="flex">
            <!-- Sidebar (hidden on mobile and tablet) -->
            <div class="hidden lg:flex flex-col w-56 bg-gray-50 border-r border-gray-200 p-4">
              <div class="flex items-center gap-2 mb-6 pb-4 border-b border-gray-200">
                <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center">
                  <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                  </svg>
                </div>
                <span class="text-sm font-display font-bold text-gray-900">Merrily Plan</span>
              </div>
              <nav class="space-y-1">
                <div class="px-3 py-2 rounded-lg bg-primary-50 text-primary-700 text-sm font-medium">{t(locale, 'home.appPreview.sidebar.dashboard')}</div>
                <div class="px-3 py-2 rounded-lg text-gray-600 text-sm">{t(locale, 'home.appPreview.sidebar.weddingBudget')}</div>
                <div class="px-3 py-2 rounded-lg text-gray-600 text-sm">{t(locale, 'home.appPreview.sidebar.guestList')}</div>
                <div class="px-3 py-2 rounded-lg text-gray-600 text-sm">{t(locale, 'home.appPreview.sidebar.taskTracker')}</div>
                <div class="px-3 py-2 rounded-lg text-gray-600 text-sm">{t(locale, 'home.appPreview.sidebar.seatingPlan')}</div>
                <div class="px-3 py-2 rounded-lg text-gray-600 text-sm">{t(locale, 'home.appPreview.sidebar.vendorComparison')}</div>
                <div class="px-3 py-2 rounded-lg text-gray-600 text-sm">{t(locale, 'home.appPreview.sidebar.dayTimeline')}</div>
                <div class="px-3 py-2 rounded-lg text-gray-400 text-xs mt-2">{t(locale, 'home.appPreview.sidebar.moreTabs')}</div>
              </nav>
            </div>

            <!-- Main content area -->
            <div class="flex-1 p-4 sm:p-6 md:p-8">
              <div class="flex items-center justify-between mb-4 sm:mb-8">
                <div>
                  <h3 class="text-sm sm:text-lg font-display font-bold text-gray-900">{t(locale, 'home.appPreview.dashboardTitle')}</h3>
                  <p class="text-xs sm:text-sm text-gray-500">{t(locale, 'home.appPreview.dashboardSubtitle')}</p>
                </div>
                <div class="hidden sm:flex items-center gap-2">
                  <div class="px-3 py-1.5 rounded-lg bg-green-50 text-green-700 text-xs font-medium">{t(locale, 'home.appPreview.onTrack')}</div>
                </div>
              </div>

              <!-- Stats cards -->
              <div class="grid grid-cols-2 lg:grid-cols-4 gap-2 sm:gap-4 mb-4 sm:mb-8">
                <div class="bg-primary-50 rounded-lg sm:rounded-xl p-2.5 sm:p-4">
                  <p class="text-[10px] sm:text-xs text-primary-600 font-medium mb-0.5 sm:mb-1">{t(locale, 'home.appPreview.budget')}</p>
                  <p class="text-sm sm:text-lg font-bold text-gray-900">$24,500</p>
                  <p class="text-[10px] sm:text-xs text-gray-500">{t(locale, 'home.appPreview.budgetOf')}</p>
                </div>
                <div class="bg-blue-50 rounded-lg sm:rounded-xl p-2.5 sm:p-4">
                  <p class="text-[10px] sm:text-xs text-blue-600 font-medium mb-0.5 sm:mb-1">{t(locale, 'home.appPreview.guests')}</p>
                  <p class="text-sm sm:text-lg font-bold text-gray-900">142</p>
                  <p class="text-[10px] sm:text-xs text-gray-500">{t(locale, 'home.appPreview.guestsConfirmed')}</p>
                </div>
                <div class="bg-green-50 rounded-lg sm:rounded-xl p-2.5 sm:p-4">
                  <p class="text-[10px] sm:text-xs text-green-600 font-medium mb-0.5 sm:mb-1">{t(locale, 'home.appPreview.tasks')}</p>
                  <p class="text-sm sm:text-lg font-bold text-gray-900">28/45</p>
                  <p class="text-[10px] sm:text-xs text-gray-500">{t(locale, 'home.appPreview.tasksDone')}</p>
                </div>
                <div class="bg-purple-50 rounded-lg sm:rounded-xl p-2.5 sm:p-4">
                  <p class="text-[10px] sm:text-xs text-purple-600 font-medium mb-0.5 sm:mb-1">{t(locale, 'home.appPreview.vendorsLabel')}</p>
                  <p class="text-sm sm:text-lg font-bold text-gray-900">8</p>
                  <p class="text-[10px] sm:text-xs text-gray-500">{t(locale, 'home.appPreview.vendorsConfirmed')}</p>
                </div>
              </div>

              <!-- Progress bar -->
              <div class="mb-4 sm:mb-8">
                <div class="flex items-center justify-between text-xs sm:text-sm mb-1.5 sm:mb-2">
                  <span class="font-medium text-gray-700">{t(locale, 'home.appPreview.overallProgress')}</span>
                  <span class="text-primary-600 font-semibold">62%</span>
                </div>
                <div class="w-full bg-gray-100 rounded-full h-2 sm:h-3">
                  <div class="bg-gradient-to-r from-primary-500 to-accent-500 h-2 sm:h-3 rounded-full" style="width: 62%"></div>
                </div>
              </div>

              <!-- Upcoming tasks preview (hidden on very small screens) -->
              <div class="hidden sm:block">
                <h4 class="text-sm font-semibold text-gray-700 mb-3">{t(locale, 'home.appPreview.upcomingTasks')}</h4>
                <div class="space-y-2">
                  <div class="flex items-center gap-3 p-3 rounded-lg bg-gray-50">
                    <div class="w-5 h-5 rounded border-2 border-primary-400 flex-shrink-0"></div>
                    <span class="text-sm text-gray-700">{t(locale, 'home.appPreview.task1')}</span>
                    <span class="ml-auto text-xs text-gray-400 whitespace-nowrap">Mar 20</span>
                  </div>
                  <div class="flex items-center gap-3 p-3 rounded-lg bg-gray-50">
                    <div class="w-5 h-5 rounded border-2 border-primary-400 flex-shrink-0"></div>
                    <span class="text-sm text-gray-700">{t(locale, 'home.appPreview.task2')}</span>
                    <span class="ml-auto text-xs text-gray-400 whitespace-nowrap">Mar 25</span>
                  </div>
                  <div class="flex items-center gap-3 p-3 rounded-lg bg-gray-50">
                    <div class="w-5 h-5 rounded border-2 border-gray-300 flex-shrink-0 bg-white"></div>
                    <span class="text-sm text-gray-700">{t(locale, 'home.appPreview.task3')}</span>
                    <span class="ml-auto text-xs text-gray-400 whitespace-nowrap">Apr 1</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Shadow and glow effect -->
        <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 w-3/4 h-12 bg-primary-500/10 blur-2xl rounded-full"></div>
      </div>

      <div class="text-center mt-10 md:mt-12">
        <a href={appUrl(locale)} class="btn-primary text-base sm:text-lg px-8 sm:px-10 py-3 sm:py-4">
          {t(locale, 'home.appPreview.ctaTryFree')}
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="py-20 md:py-28 bg-gradient-to-br from-primary-50 to-accent-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="section-heading mb-4">
          {t(locale, 'home.testimonials.heading')}
          <span class="gradient-text">{t(locale, 'home.testimonials.headingHighlight')}</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {testimonials.map(({ quote, name, role }) => (
          <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-100">
            <div class="flex gap-1 mb-4">
              {[...Array(5)].map(() => (
                <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <blockquote class="text-gray-700 leading-relaxed mb-6">
              "{quote}"
            </blockquote>
            <div>
              <div class="font-semibold text-gray-900">{name}</div>
              <div class="text-sm text-gray-500">{role}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Trust Signals / Social Proof Section -->
  <section class="py-16 md:py-20 bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-sm font-semibold uppercase tracking-wider text-gray-400 mb-6">{t(locale, 'home.trustSignals.trustedBy')}</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 items-center justify-items-center">
          <div class="flex flex-col items-center gap-1">
            <span class="text-3xl font-display font-bold text-gray-800">10,000+</span>
            <span class="text-sm text-gray-500">{t(locale, 'home.trustSignals.plansCreated')}</span>
          </div>
          <div class="flex flex-col items-center gap-1">
            <span class="text-3xl font-display font-bold text-gray-800">50+</span>
            <span class="text-sm text-gray-500">{t(locale, 'home.trustSignals.countries')}</span>
          </div>
          <div class="flex flex-col items-center gap-1">
            <span class="text-3xl font-display font-bold text-gray-800">4.8/5</span>
            <span class="text-sm text-gray-500">{t(locale, 'home.trustSignals.avgRating')}</span>
          </div>
          <div class="flex flex-col items-center gap-1">
            <span class="text-3xl font-display font-bold text-gray-800">32+</span>
            <span class="text-sm text-gray-500">{t(locale, 'home.trustSignals.planningToolsLabel')}</span>
          </div>
        </div>
      </div>

      <!-- As Featured In (placeholder logos represented as text badges) -->
      <div class="mt-12 pt-8 border-t border-gray-100">
        <p class="text-sm font-semibold uppercase tracking-wider text-gray-400 text-center mb-8">{t(locale, 'home.trustSignals.featuredIn')}</p>
        <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12 opacity-50">
          <span class="text-xl font-display font-bold text-gray-400 hover:text-gray-600 transition-colors">WeddingWire</span>
          <span class="text-xl font-display font-bold text-gray-400 hover:text-gray-600 transition-colors">The Knot</span>
          <span class="text-xl font-display font-bold text-gray-400 hover:text-gray-600 transition-colors">Brides</span>
          <span class="text-xl font-display font-bold text-gray-400 hover:text-gray-600 transition-colors">Vogue</span>
          <span class="text-xl font-display font-bold text-gray-400 hover:text-gray-600 transition-colors">TechCrunch</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 md:py-24 bg-gray-50">
