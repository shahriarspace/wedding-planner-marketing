      <div class="text-center mb-12">
        <h2 class="section-heading mb-4">
          {t(locale, 'home.faq.heading')}
          <span class="gradient-text">{t(locale, 'home.faq.headingHighlight')}</span>
        </h2>
        <p class="section-subheading">
          {t(locale, 'home.faq.subheading')}
        </p>
      </div>

      <div class="space-y-4">
        {homeFaqs.map(({ q, a }) => (
          <details class="group bg-white rounded-xl p-6 shadow-sm border border-gray-100 cursor-pointer">
            <summary class="flex items-center justify-between font-semibold text-gray-900 list-none">
              {q}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-4 text-gray-600 leading-relaxed">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Platform Section -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="section-heading mb-4">
          {t(locale, 'home.platforms.heading')}
          <span class="gradient-text">{t(locale, 'home.platforms.headingHighlight')}</span>
        </h2>
        <p class="section-subheading">
          {t(locale, 'home.platforms.subheading')}
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
        {[
          { name: t(locale, 'home.platforms.webPwa'), icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9' },
          { name: t(locale, 'home.platforms.android'), icon: 'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z' },
          { name: t(locale, 'home.platforms.ios'), icon: 'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z' },
          { name: t(locale, 'home.platforms.windows'), icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
          { name: t(locale, 'home.platforms.macos'), icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
          { name: t(locale, 'home.platforms.linux'), icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
        ].map(({ name, icon }) => (
          <div class="flex flex-col items-center gap-3 p-6 rounded-xl bg-gray-50 hover:bg-primary-50 transition-colors">
            <svg class="w-8 h-8 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} />
