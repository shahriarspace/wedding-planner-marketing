---
import BaseLayout from '../layouts/BaseLayout.astro';
import { localePath } from '../utils/url';
import { getLocaleFromUrl, t, type Locale } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url) as Locale;
---

<BaseLayout
  title={t(locale, 'comingSoon.title')}
  description={t(locale, 'comingSoon.description')}
  noindex={true}
>
  <section class="relative overflow-hidden py-20 md:py-32 bg-gradient-to-br from-primary-50 via-white to-accent-50 min-h-[70vh] flex items-center">
    <!-- Decorative elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-40 -right-40 w-96 h-96 rounded-full bg-primary-200/30 blur-3xl"></div>
      <div class="absolute -bottom-40 -left-40 w-96 h-96 rounded-full bg-accent-200/30 blur-3xl"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-primary-100/20 blur-3xl"></div>
    </div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary-100 text-primary-700 text-sm font-medium mb-8 animate-fade-in">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        {t(locale, 'comingSoon.badge')}
      </div>

      <!-- Heart icon -->
      <div class="mb-8 animate-slide-up">
        <div class="w-20 h-20 mx-auto rounded-2xl bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center shadow-xl shadow-primary-500/20">
          <svg class="w-10 h-10 text-white" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
          </svg>
        </div>
      </div>

      <!-- Heading -->
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold text-gray-900 leading-tight mb-6 animate-slide-up" style="animation-delay: 0.1s">
        {t(locale, 'comingSoon.heading')}
        <span class="gradient-text">{t(locale, 'comingSoon.headingHighlight')}</span>
      </h1>

      <p class="text-lg md:text-xl text-gray-600 max-w-2xl mx-auto mb-12 animate-slide-up" style="animation-delay: 0.2s">
        {t(locale, 'comingSoon.text')}
      </p>

      <!-- Feature pills -->
      <div class="flex flex-wrap items-center justify-center gap-3 mb-12 animate-slide-up" style="animation-delay: 0.3s">
        {[
          { text: t(locale, 'comingSoon.feature1'), icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2' },
          { text: t(locale, 'comingSoon.feature2'), icon: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z' },
          { text: t(locale, 'comingSoon.feature3'), icon: 'M18.364 5.636a9 9 0 010 12.728m0 0l-2.829-2.829m2.829 2.829L21 21M15.536 8.464a5 5 0 010 7.072m0 0l-2.829-2.829m-4.243 2.829a4.978 4.978 0 01-1.414-2.83m-1.414 5.658a9 9 0 01-2.167-9.238m7.824 2.167a1 1 0 111.414 1.414m-1.414-1.414L3 3' },
          { text: t(locale, 'comingSoon.feature4'), icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
        ].map(({ text, icon }) => (
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white shadow-sm border border-gray-100 text-sm text-gray-700">
            <svg class="w-4 h-4 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon} />
            </svg>
            {text}
          </div>
        ))}
      </div>

      <!-- Email notify form -->
      <div class="max-w-md mx-auto mb-12 animate-slide-up" style="animation-delay: 0.4s">
        <p class="text-sm font-semibold text-gray-700 mb-2">{t(locale, 'comingSoon.notifyHeading')}</p>
        <p class="text-sm text-gray-500 mb-4">{t(locale, 'comingSoon.notifyText')}</p>
        <form id="notify-form" class="flex gap-2">
          <input
            type="email"
            required
            placeholder={t(locale, 'comingSoon.emailPlaceholder')}
            aria-label={t(locale, 'comingSoon.emailAria')}
            class="flex-1 px-4 py-3 rounded-full border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent"
          />
          <button
            type="submit"
            class="px-6 py-3 rounded-full bg-primary-600 text-white text-sm font-semibold hover:bg-primary-700 transition-colors shadow-md"
          >
            {t(locale, 'comingSoon.notifyButton')}
          </button>
        </form>
        <p id="notify-success" class="hidden mt-3 text-sm text-green-600 font-medium">{t(locale, 'comingSoon.successMessage')}</p>
        <p id="notify-error" class="hidden mt-3 text-sm text-red-600 font-medium">{t(locale, 'comingSoon.errorMessage')}</p>
      </div>

      <!-- Navigation buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up" style="animation-delay: 0.5s">
        <a href={localePath(locale, '/')} class="btn-primary">
          {t(locale, 'comingSoon.goHome')}
        </a>
        <a href={localePath(locale, '/pricing')} class="btn-secondary">
          {t(locale, 'comingSoon.viewPricing')}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('notify-form') as HTMLFormElement;
  const successMsg = document.getElementById('notify-success');
  const errorMsg = document.getElementById('notify-error');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    // For now, just show success (no backend yet)
    successMsg?.classList.remove('hidden');
    errorMsg?.classList.add('hidden');
    form.reset();
  });
</script>
