---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Merrily Plan',
  applicationCategory: 'LifestyleApplication',
  operatingSystem: 'Web, Android, iOS, Windows, macOS, Linux',
  url: 'https://merrilyplan.com',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
    description: 'Free tier with all 32 planning tabs',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    ratingCount: '1200',
  },
  description: 'The all-in-one wedding planning app with 32+ planning tools, AI assistance, and multi-platform support.',
};

const features = [
  {
    icon: 'clipboard-list',
    title: '32+ Planning Tabs',
    description: 'From budget tracking and guest lists to seating plans and day-of timelines. Every tool you need in one place.',
  },
  {
    icon: 'sparkles',
    title: 'AI-Powered Assistance',
    description: 'Smart suggestions for budgets, timelines, vendor questions, and more. Let AI handle the complexity.',
  },
  {
    icon: 'users',
    title: 'Collaborate Together',
    description: 'Share your plan with your partner, family, or wedding planner. Real-time collaboration keeps everyone aligned.',
  },
  {
    icon: 'smartphone',
    title: 'Works Everywhere',
    description: 'Web, Android, iOS, Windows, macOS, and Linux. Plan from your desk or on the go.',
  },
  {
    icon: 'lock',
    title: 'Your Data, Your Way',
    description: 'Works completely offline with local storage. No account required for the free tier.',
  },
  {
    icon: 'globe',
    title: '10 Languages',
    description: 'Available in English, Spanish, French, German, Portuguese, Italian, Japanese, Chinese, Korean, and Hindi.',
  },
];

const tabGroups = [
  {
    category: 'Getting Started',
    tabs: ['Setup', 'Priorities', 'Couple Profile', 'Moodboard'],
  },
  {
    category: 'Budget & Finances',
    tabs: ['Wedding Budget', 'Honeymoon Budget'],
  },
  {
    category: 'Guests & Seating',
    tabs: ['Guest List', 'Seating Plan', 'Wedding Party', 'Invitations'],
  },
  {
    category: 'Planning & Tasks',
    tabs: ['Task Tracker', 'Appointments', 'Smart Calendar'],
  },
  {
    category: 'Vendors',
    tabs: ['Venue Options', 'Vendor Comparison', 'Confirmed Vendors', 'Vendor Questions'],
  },
  {
    category: 'Event Details',
    tabs: ['Food & Drinks', 'Logistics', 'Decor', 'Music Playlist', 'Photo Shotlist'],
  },
  {
    category: 'The Big Day',
    tabs: ['Day Timeline', 'Packing List'],
  },
  {
    category: 'After the Wedding',
    tabs: ['Gift & Thank-You Log', 'Couple Blog'],
  },
  {
    category: 'Overview & Export',
    tabs: ['Dashboard', 'Printable Summary', 'Wedding Trailer', 'Inspiration Gallery'],
  },
];

const testimonials = [
  {
    quote: 'Merrily Plan made our wedding planning so much less stressful. The budget tracker alone saved us thousands!',
    name: 'Sarah & James',
    role: 'Married October 2025',
  },
  {
    quote: 'As a professional wedding planner, I recommend Merrily Plan to all my clients. The collaboration features are outstanding.',
    name: 'Rebecca Torres',
    role: 'Wedding Planner, 8+ years',
  },
  {
    quote: 'We loved that everything works offline. We planned our destination wedding from planes, hotels, and coffee shops.',
    name: 'Mia & David',
    role: 'Married June 2025',
  },
];

const stats = [
  { value: '32+', label: 'Planning Tools' },
  { value: '10', label: 'Languages' },
  { value: '6', label: 'Platforms' },
  { value: '100%', label: 'Free to Start' },
];
---

<BaseLayout
  title="Merrily Plan"
  description="The all-in-one wedding planning app with 32+ planning tools, AI assistance, offline support, and multi-platform availability. Free to start, no account required."
  jsonLd={jsonLd}
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-primary-50 via-white to-accent-50">
    <!-- Decorative elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-40 -right-40 w-80 h-80 rounded-full bg-primary-200/30 blur-3xl"></div>
      <div class="absolute -bottom-40 -left-40 w-80 h-80 rounded-full bg-accent-200/30 blur-3xl"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28 lg:py-36">
      <div class="text-center max-w-4xl mx-auto">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary-100 text-primary-700 text-sm font-medium mb-6 animate-fade-in">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
          </svg>
          Free to use &middot; No account required
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-display font-bold text-gray-900 leading-tight mb-6 animate-slide-up">
          Plan Your Dream Wedding,
          <span class="gradient-text"> Merrily.</span>
        </h1>

        <p class="text-lg md:text-xl text-gray-600 max-w-2xl mx-auto mb-10 animate-slide-up" style="animation-delay: 0.1s">
          The all-in-one wedding planning app with 32+ tools, AI-powered assistance,
          and offline support. Works on every platform. Free to start.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up" style="animation-delay: 0.2s">
          <a href="https://app.merrilyplan.com" class="btn-primary text-lg px-10 py-4">
            Start Planning Free
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a href="#features" class="btn-secondary text-lg px-10 py-4">
            See Features
          </a>
        </div>

        <!-- Stats -->
        <div class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-8 animate-fade-in" style="animation-delay: 0.4s">
          {stats.map(({ value, label }) => (
            <div class="text-center">
              <div class="text-3xl md:text-4xl font-display font-bold gradient-text">{value}</div>
              <div class="text-sm text-gray-500 mt-1">{label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section id="features" class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="section-heading mb-4">
          Everything You Need to Plan
          <span class="gradient-text"> the Perfect Day</span>
        </h2>
        <p class="section-subheading">
          From the first budget estimate to the last thank-you note, Merrily Plan guides you through every step.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {features.map(({ icon, title, description }, index) => (
          <div class="card group" style={`animation-delay: ${index * 0.1}s`}>
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300">
              {icon === 'clipboard-list' && (
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                </svg>
              )}
              {icon === 'sparkles' && (
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                </svg>
              )}
              {icon === 'users' && (
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
              )}
              {icon === 'smartphone' && (
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
                </svg>
              )}
              {icon === 'lock' && (
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
              )}
              {icon === 'globe' && (
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              )}
            </div>
            <h3 class="text-xl font-display font-bold text-gray-900 mb-2">{title}</h3>
            <p class="text-gray-600 leading-relaxed">{description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- All 32 Tabs Section -->
  <section class="py-20 md:py-28 bg-gradient-to-br from-gray-50 to-primary-50/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="section-heading mb-4">
          32+ Planning Tools,
          <span class="gradient-text"> One App</span>
        </h2>
        <p class="section-subheading">
          Every tool a couple or wedding planner could ever need, organized into intuitive categories.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {tabGroups.map(({ category, tabs }) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <h3 class="text-sm font-semibold uppercase tracking-wider text-primary-600 mb-3">{category}</h3>
            <ul class="space-y-2">
              {tabs.map((tab) => (
                <li class="flex items-center gap-2 text-gray-700">
                  <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {tab}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="section-heading mb-4">
          Start Planning in
          <span class="gradient-text"> 3 Simple Steps</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
        <div class="text-center">
          <div class="w-16 h-16 rounded-full bg-primary-100 text-primary-600 flex items-center justify-center mx-auto mb-6 text-2xl font-display font-bold">
            1
          </div>
          <h3 class="text-xl font-display font-bold text-gray-900 mb-3">Open the App</h3>
          <p class="text-gray-600">
            No sign-up required. Just open Merrily Plan in your browser or download the app. Your data stays on your device.
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 rounded-full bg-primary-100 text-primary-600 flex items-center justify-center mx-auto mb-6 text-2xl font-display font-bold">
            2
          </div>
          <h3 class="text-xl font-display font-bold text-gray-900 mb-3">Set Your Priorities</h3>
          <p class="text-gray-600">
            Tell us your wedding date, budget, and what matters most. Merrily Plan creates a personalized planning roadmap.
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 rounded-full bg-primary-100 text-primary-600 flex items-center justify-center mx-auto mb-6 text-2xl font-display font-bold">
            3
          </div>
          <h3 class="text-xl font-display font-bold text-gray-900 mb-3">Plan Together</h3>
          <p class="text-gray-600">
            Use 32+ tools to track budgets, manage guests, compare vendors, and coordinate every detail of your special day.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="py-20 md:py-28 bg-gradient-to-br from-primary-50 to-accent-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="section-heading mb-4">
          Loved by Couples
          <span class="gradient-text"> & Planners</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {testimonials.map(({ quote, name, role }) => (
          <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-100">
            <div class="flex gap-1 mb-4">
              {[...Array(5)].map(() => (
                <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <blockquote class="text-gray-700 leading-relaxed mb-6">
              "{quote}"
            </blockquote>
            <div>
              <div class="font-semibold text-gray-900">{name}</div>
              <div class="text-sm text-gray-500">{role}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Platform Section -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="section-heading mb-4">
          Plan from
          <span class="gradient-text"> Any Device</span>
        </h2>
        <p class="section-subheading">
          Merrily Plan works on every major platform. Start on your laptop, continue on your phone.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
        {[
          { name: 'Web / PWA', icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9' },
          { name: 'Android', icon: 'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z' },
          { name: 'iOS', icon: 'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z' },
          { name: 'Windows', icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
          { name: 'macOS', icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
          { name: 'Linux', icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
        ].map(({ name, icon }) => (
          <div class="flex flex-col items-center gap-3 p-6 rounded-xl bg-gray-50 hover:bg-primary-50 transition-colors">
            <svg class="w-8 h-8 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} />
            </svg>
            <span class="text-sm font-medium text-gray-700">{name}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA Section -->
  <section class="py-20 md:py-28 bg-gradient-to-br from-primary-600 to-accent-600 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-bold mb-6">
        Your Perfect Day Starts Here
      </h2>
      <p class="text-lg md:text-xl text-white/80 max-w-2xl mx-auto mb-10">
        Join thousands of couples and wedding planners who trust Merrily Plan to organize every detail. Free forever, no credit card required.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="https://app.merrilyplan.com"
          class="inline-flex items-center px-10 py-4 rounded-full bg-white text-primary-700 font-semibold text-lg hover:bg-gray-100 transition-all duration-200 shadow-xl hover:shadow-2xl hover:-translate-y-0.5"
        >
          Start Planning Free
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a
          href="/pricing"
          class="inline-flex items-center px-10 py-4 rounded-full border-2 border-white/50 text-white font-semibold text-lg hover:bg-white/10 transition-all duration-200"
        >
          View Pricing
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
